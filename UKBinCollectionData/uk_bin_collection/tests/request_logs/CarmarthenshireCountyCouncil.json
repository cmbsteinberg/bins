      "response_body": "<div class=\"clearfix\">\r\n\r\n            <div class=\"col-lg-3 col-md-3 col-sm-3 col-xs-12 recycling-outer-container\">\r\n                <div class=\"bin-day-container Blue\">\r\n                    <p class=\"margin-bottom-15 font1\"><span class=\"fas fa-trash\"></span> Your next blue bag and green food bin collection</p><p class=\"font11 text-center\">Wednesday  31/12/2025</p>\r\n                    <p class=\"margin-top-15 font1\"><span class=\"far fa-calendar-alt\"></span> Collected every week </p>\r\n                </div>\r\n            </div>\r\n            <div class=\"col-lg-3 col-md-3 col-sm-3 col-xs-12 recycling-outer-container\">\r\n                <div class=\"bin-day-container Black\">\r\n                    <p class=\"margin-bottom-15 font1\"><span class=\"fas fa-trash\"></span> Your next black bag and glass box collection</p><p class=\"font11 text-center\">Wednesday  31/12/2025</p>\r\n                    <p class=\"margin-top-15 font1\"><a target=\"_blank\" href=\"https://www.carmarthenshire.gov.wales/media/21bps2ay/sr-64058-calendarsblkglass-en-2025-1.pdf\" class=\"underline-white\"><span class=\"fas fa-cloud-download-alt\"></span> Download bin collection calendar </a></p>\r\n                     <p class=\"margin-top-20 font1\"><a target=\"_blank\" href=\"https://www.carmarthenshire.gov.wales/media/k0bbp4ti/sr-87832_calendarsblackglass2026_w1_english.pdf\" class=\"underline-white\"><span class=\"fas fa-cloud-download-alt\"></span> Download bin collection calendar 2026 </a></p>\r\n                </div>\r\n            </div>\r\n\r\n     <div class=\"col-lg-3 col-md-3 col-sm-3 col-xs-12 garden-waste-container hidden\">\r\n         <div class=\"bin-day-container Garden\">\r\n             <p class=\"font1\">Garden waste collections will resume in February</p>\r\n\r\n         </div>\r\n     </div>\r\n\r\n        <div class=\"col-lg-3 col-md-3 col-sm-3 col-xs-12 nappy-waste-container hidden\">\r\n            <div class=\"bin-day-container Nappy\">\r\n                <p class=\"margin-bottom-15 font1\"><span class=\"far fa-trash-alt\"></span> Your next hygiene waste collection</p><p class=\"font11 text-center\">Thursday  08/01/2026 </p>\r\n                    <p class=\"margin-top-15 font1\"><a target=\"_blank\" href=\"https://www.carmarthenshire.gov.wales/media/bxrg3se4/sr-64059-calendarsahp-1-v2-1.pdf\" class=\"underline-white\"><span class=\"fas fa-cloud-download-alt\"></span> Download hygiene waste calendar </a></p>\r\n                    <p class=\"margin-top-20 font1\"><a target=\"_blank\" href=\"https://www.carmarthenshire.gov.wales/media/cw3d52dp/sr-87830_calendarsahp2026_w1_english.pdf\" class=\"underline-white\"><span class=\"fas fa-cloud-download-alt\"></span> Download hygiene waste calendar 2026 </a></p>\r\n            </div>\r\n        </div>\r\n\r\n\r\n\r\n</div>\r\n<div class=\"bin-additional-info\">\r\n    <p class=\"margin-bottom-0\">\r\n        Please remember to put your rubbish out the night before. <span class=\"bag-info-message\"></span> Don&#x27;t forget we collect your food bin every week.\r\n            <span class=\"garden-waste-additional-info hidden\">\r\n                The garden waste collection is a paid for service.  <a href=\"https://www.carmarthenshire.gov.wales/home/council-services/recycling-bins-and-litter/garden-waste\">Find out more information and how to apply.</a>\r\n            </span>\r\n            <span class=\"nappy-waste-additional-info hidden\">\r\n                You must <a href=\"https://myaccount.carmarthenshire.gov.wales/en/service/Hygiene_And_Nappy_Waste_Service\">apply to receive a hygiene collection</a>, there is no charge for this service. <a href=\"https://www.carmarthenshire.gov.wales/home/council-services/recycling-bins-and-litter/hygiene-and-nappy-waste/\">Find out more about hygiene collections.</a>\r\n            </span>\r\n    </p>\r\n</div>\r\n",
