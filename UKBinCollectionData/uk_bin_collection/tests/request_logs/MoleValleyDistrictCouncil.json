                "three_column_layout_html": "\n\t<!-- Column 1 -->\n\t<div class=\"col-md-4\">\n\t\t<div class=\"panel\">\n\t\t\t<!-- For consistency you way want to pull the <h2> out to here -->\n\t\t\t<h2>Property</h2>\n<iframe id=\"mappin_overview_map\" frameborder=\"0\" width=\"100%\" src=\"\" height=\"200\"></iframe>\n<a href=\"#\" onclick=\"showMainMapProg(); return false;\"><strong>View in larger map</strong></a>\n<br/>\n<br/>\n<strong>Selected address:</strong>\n<p>Mole Valley DC, Pippbrook Council Offices, Reigate Road, Dorking, RH4 1SJ</p>\n<strong>Unique Property Reference Number (UPRN):</strong>\n<p>200000171235</p>\n\t\t</div>\n\t\t<div class=\"panel\">\n\t\t\t<h2>Bins and Recycling</h2>\n\t\t\t<p>Please ensure your bins are out for collection by 6.00am.</p>\n<!--<a rel=\"noopener noreferrer\" target=\"_blank\" href=\"https://www.molevalley.gov.uk/waste-recycling/calendar-collection-day/\" style=\"color: rgb(212, 144, 255) !important;\">Collection Day Calendar</a>-->\n<strong>Refuse (black bin)</strong>\n<p>Next collection - <strong>No collection dates available</strong></p>\n\n<strong>Recycling (green bin)</strong>\n<p>Next collection - <strong>(Sat) 03/01/2026</strong></p>\n\n<strong>Garden Waste (brown lid)</strong>\n<p>Not a Garden Waste member</p>\n\n<strong>Food Waste</strong>\n<p>Next collection - <strong>No collection dates available</strong></p>\n\n<p>We also collect Small Electricals and Textiles on each collection day - <a href=\"https://www.molevalley.gov.uk/waste-recycling/bins-what-goes-in-them/\" target = \"_blank\"><strong>Read more</strong></a></p>\n\n<hr>\n<h4>Additional Services</h4>\n<p>Report a <a href=\"https://molevalley-self.achieveservice.com/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-83f2f07b-03af-4d20-b33c-7549688156ee/AF-Stage-5ab08e8d-bcbe-4d7a-8b7d-d121bc49f30d/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes\" target = \"_blank\"><strong>Missed Bin</strong></a> collection</p>\n<p><a href = \"https://www.molevalley.gov.uk/waste-recycling/garden-waste-composting/\" target = \"_blank\"><strong>Sign Up or Manage</strong></a> Garden Waste collection service</p>\n<p><a href = \"https://www.molevalley.gov.uk/waste-recycling/assisted-bin/\" target = \"_blank\"><strong>Sign Up</strong></a> for the Assisted Bin collection service</p>\n\n\t\t</div>\n\t\t<div class=\"panel\">\n\t\t\t<h2>Planning Applications</h2>\n\t\t\t<p>Ref: <a href=\"https://molevalley-publicportal.statmap.co.uk/horizoNext/publicportal/planningapplications/118617\"  target = \"external_tab\"><strong>MO/2021/0938</strong></a></p>\n        <p><strong>Location: </strong>Pippbrook Council Offices, Reigate Road, Dorking, Surrey, RH4 1SJ </p>\n        <p><strong>Status: </strong> Determined</p>\n        <p><strong>Decision: </strong>APPROVED WITH CONDITIONS</p>\n        <p><strong>Proposal: </strong>Installation of a new air source heat pump 1295high x 795 wide x 765 deep installed below the carpark entrance ramp to the upper loading bay area. The heat pump will sit on a concrete base and be surrounded by a security steel cage.</p>\n        <hr>\n        <p>Ref: <a href=\"https://molevalley-publicportal.statmap.co.uk/horizoNext/publicportal/planningapplications/22845\"  target = \"external_tab\"><strong>MO/2005/0304</strong></a></p>\n        <p><strong>Location: </strong>Pippbrook House, Reigate Road, Dorking, Surrey, RH4 1SH </p>\n        <p><strong>Status: </strong> Determined</p>\n        <p><strong>Decision: </strong>GOSE CALL IN</p>\n        <p><strong>Proposal: </strong>Security bars across moat to south and west of Pippbrook House. Security grilles to internal face of 13 windows at basement level.</p>\n        <hr>\n        <p>Ref: <a href=\"https://molevalley-publicportal.statmap.co.uk/horizoNext/publicportal/planningapplications/79034\"  target = \"external_tab\"><strong>MO/82/0527</strong></a></p>\n        <p><strong>Location: </strong>Reigate Road , Dorking </p>\n        <p><strong>Status: </strong> Determined</p>\n        <p><strong>Decision: </strong>APPROVED WITH CONDITIONS</p>\n        <p><strong>Proposal: </strong>Seven, 3 habitable room flats in a three or four storey building of 515 sq m (5540 sq ft) inclusive of 7 single garages on a site of 0.16 acres (0.0655 ha).</p>\n        <hr>\n        <p>Ref: <a href=\"https://molevalley-publicportal.statmap.co.uk/horizoNext/publicportal/planningapplications/77850\"  target = \"external_tab\"><strong>MO/81/0674</strong></a></p>\n        <p><strong>Location: </strong>(Pippbrook) , Land adjacent to , Reigate Road , Dorking </p>\n        <p><strong>Status: </strong> Determined</p>\n        <p><strong>Decision: </strong>APPROVED WITH CONDITIONS</p>\n        <p><strong>Proposal: </strong>Details of new headquarters building for Mole Valley District Council of 39,500 sq ft (3670 sq m) including offices on a split level ground floor, a print room on a mezzanine floor with towers containing a council chamber, members' room, committee room and staff area at first floor level and a service area and public gallery at second floor level, as well as a caretaker's house and a storage area to be used as a war time headquarters, with not less than 152 parking spaces and a tree planting scheme, with two vehicular accesses and pedestrian access from A.25 following demolition of the former Embassy Cinema, Bakers Garage and the Library, all within a site of 3.15 acres (1.274 ha).</p>\n        <hr>\n        <p>Ref: <a href=\"https://molevalley-publicportal.statmap.co.uk/horizoNext/publicportal/planningapplications/49367\"  target = \"external_tab\"><strong>DOR/4722</strong></a></p>\n        <p><strong>Location: </strong>Dorking Urban District Council Offices , Pippbrook , Dorking </p>\n        <p><strong>Status: </strong> Determined</p>\n        <p><strong>Decision: </strong>APPROVED</p>\n        <p><strong>Proposal: </strong>Single storey office building of 1128 sq. ft.</p>\n        <hr>\n        \n\n<p><strong