      "response_body": "\r\n\r\n<!DOCTYPE html>\r\n\r\n<html lang=\"en\">\r\n\r\n<head><meta charset=\"utf-8\" /><meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\" /><link href=\"Content/bootstrap.min.css\" rel=\"stylesheet\" />\r\n    <script src=\"Scripts/jquery-3.7.1.js\"></script>\r\n    <script src=\"Scripts/bootstrap.min.js\"></script>\r\n\r\n    <link href=\"App_Themes/SMBC/smbc_site.css\" rel=\"stylesheet\" /><link href=\"Content/site.css\" rel=\"stylesheet\" />\r\n\r\n    <script src=\"fontawesome/all.js\"></script>\r\n\r\n    <title>\r\n\t\r\n        Bin Collection Calendar\r\n    \r\n</title></head>\r\n\r\n<body>\r\n\r\n    <link rel=\"stylesheet\" media=\"all\" href=\"https://fonts.googleapis.com/css?family=Lato:ital,wght@0,400;1,700&amp;display=swap\" />\r\n\r\n<div class=\"logo-outer\">\r\n\r\n\t<div class=\"container-xl\">\r\n\t\t<div class=\"logo-inner\">\r\n\t\t\t<a class='logo' href=\"https://www.solihull.gov.uk/\">solihull.gov.uk</a>\r\n\t\t</div>\r\n\t</div>\r\n\r\n</div>\r\n\r\n<div class=\"container\">\r\n\r\n    <form method=\"post\" action=\"./Calendar.aspx?UPRN=100071005444\" id=\"form1\" role=\"form\">\r\n<div class=\"aspNetHidden\">\r\n<input type=\"hidden\" name=\"__VIEWSTATE\" id=\"__VIEWSTATE\" value=\"dhdv/X+JzsUuhfD16nu4eNYkVU9cwbv1m/biWHeprHSqdsOGOHtbdYZDvxKnghzEAPHCNnk7+NTICL13k2hUQq8sitKy9+pLGmY9vZvq2Hc=\" />\r\n</div>\r\n\r\n<div class=\"aspNetHidden\">\r\n\r\n\t<input type=\"hidden\" name=\"__VIEWSTATEGENERATOR\" id=\"__VIEWSTATEGENERATOR\" value=\"43B8A545\" />\r\n</div>\r\n\r\n        <div class=\"mt-3\"></div>\r\n\r\n        <h1>Bin Collection Calendar</h1>\r\n        <hr />\r\n\r\n        <div id=\"panContents\">\r\n\t<div class=\"\"><a href=\"https://www.solihull.gov.uk/Rubbish-and-recycling\">Return to Rubbish & Recycling</a></div><div class=\"mt-3 mb-3\"><p>Bin collection dates for 28 Perryford Drive Hillfield Solihull B91 3XE.</p></div><div class=\"mb-3\">View your <a href=\"https://www.solihull.gov.uk/sites/default/files/2023-12/Solihull-Household-Calendar-Week-2.pdf\" target=\"_blank\">bin collection calendar <i class='fas fa-external-link-alt fa-lg'></i></a></div><div class=\"mb-4 card comms\"><div class=\"card-body\"><div class=\"row\"><div class=\"col-lg-12\"><h4 class=\"comms\">Would you like to receive an email the day before your collection is due?</h4></div></div><div class=\"row g-0\"><div class=\"mt-3 col-sm-4 col-md-3 col-lg-2\"><a href=\"ReminderSubscribe.aspx?DAY=TUESDAY&UPRN=100071005444\" target=\"_blank\" class=\"commsButton\">Get my reminder</a></div><div class=\"mt-3 col-sm-8 col-md-9 col-lg-10\"><ul class=\"comms comms-list\"><li class=\"comms-tick\">Tell me when my bin is being collected</li><li class=\"comms-tick\">Tell me which bin it is</li></ul></div></div></div></div><div class=\"mb-4 card\"><div class=\"card-body\"><div class=\"row\"><div class=\"col-xs-4 col-sm-4 col-md-3 col-lg-3 col-xl-2 text-center\"><img class=\"align-self-center mr-3\" src=\"App_Themes/Images/brownbin70px.gif\" alt=\"<h4>Brown Wheelie Bin</h4> <h5>Mixed Recycling</h5>\" /></div><div class=\"col-xs-8 col-sm-8 col-md-9 col-lg-9 col-xl-10\"><div class=\"card-title\"><h4>Brown Wheelie Bin</h4> <h5>Mixed Recycling</h5></div><div><i class='fas fa-truck'></i> Collected on a Tuesday fortnightly.</div><div class=\"mt-1\"><i class='fa-solid fa-trash-can fa-lg'></i> Your last collection was on <strong>Tuesday, 23 December 2025</strong>.</div><div class=\"mt-1\"><i class='far fa-hand-point-right fa-lg'></i> Your next collection will be on <strong>Tuesday, 6 January 2026</strong>.</div></div></div></div></div><div class=\"mb-4 card\"><div class=\"card-body\"><div class=\"row\"><div class=\"col-xs-4 col-sm-4 col-md-3 col-lg-3 col-xl-2 text-center\"><img class=\"align-self-center mr-3\" src=\"App_Themes/Images/greenbin70px.gif\" alt=\"<h4>Green Wheelie Bin</h4> <h5>Garden Waste - Subscribed</h5>\" /></div><div class=\"col-xs-8 col-sm-8 col-md-9 col-lg-9 col-xl-10\"><div class=\"card-title\"><h4>Green Wheelie Bin</h4> <h5>Garden Waste - Subscribed</h5></div><div><i class='fas fa-truck'></i> Collected on a Tuesday fortnightly.</div><div class=\"mt-1\"><i class='fa-solid fa-trash-can fa-lg'></i> Your last collection was on <strong>Tuesday, 16 December 2025</strong>.</div><div class=\"mt-1\"><i class='far fa-hand-point-right fa-lg'></i> Your next collection will be on <strong>Tuesday, 27 January 2026</strong>.</div></div></div></div></div><div class=\"mb-4 card\"><div class=\"card-body\"><div class=\"row\"><div class=\"col-xs-4 col-sm-4 col-md-3 col-lg-3 col-xl-2 text-center\"><img class=\"align-self-center mr-3\" src=\"App_Themes/Images/blackbin70px.gif\" alt=\"<h4>Black Wheelie Bin</h4> <h5>Household Waste</h5>\" /></div><div class=\"col-xs-8 col-sm-8 col-md-9 col-lg-9 col-xl-10\"><div class=\"card-title\"><h4>Black Wheelie Bin</h4> <h5>Household Waste</h5></div><div><i class='fas fa-truck'></i> Collected on a Tuesday.</div><div class=\"mt-1\"><i class='fa-solid fa-trash-can fa-lg'></i> Your last collection was on <strong>Tuesday, 23 December 2025</strong>.</div><div class=\"mt-1\"><i class='far fa-hand-point-right fa-lg'></i> Your next collection will be on <strong>Tuesday, 30 December 2025</strong>.</div></div></div></div></div>\r\n</div>\r\n\r\n        <div class=\"mt-5\"></div>\r\n\r\n        <h2>Collecting your recycling & rubbish</h2>\r\n\r\n        <p>You should ensure that your containers are presented by 6.00am on your collection day.</p>\r\n\r\n        <p>You can <a href=\"http://www.solihull.gov.uk/recyclingcollections\" target=\"_blank\">check what can go in each container</a>.</p>\r\n\r\n        <div class=\"mt-4\"></div>\r\n\r\n    </form>\r\n\r\n</div>\r\n\r\n    <link rel=\"stylesheet\" media=\"all\" href=\"https://fonts.googleapis.com/css?family=Lato:ital,wght@0,400;1,700&amp;display=swap\" />\r\n\r\n<footer class=\"footer-outer\">\r\n\r\n    <div 