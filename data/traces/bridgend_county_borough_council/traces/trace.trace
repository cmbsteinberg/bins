umb-item active","aria-current":"page"},"Refuse collections"],"\n        "],"\n    "],"\n\n        \n",["DIV",{"class":"container"},"\n\t",["DIV",{"class":"row mt-4 mb-md-3"},"\n\t\t",["DIV",{"class":"col"},"\n\t\t\t",["H1",{},"Refuse collections"],"\n\t\t"],"\n\t"],"\n"],"\n\n\n        \n\n\n\n\n",["DIV",{"class":"container"},"\n\n    ",["DIV",{"class":"row"},"\n        \n\n",["DIV",{"class":"col-md-12 col-sd-12"},"\n    \n\n\n",["DIV",{"class":"alert alert-danger","role":"alert"},"\n        ",["DIV",{"class":"alert-icon"},"\n            ",["SPAN",{"class":"fa-solid fa-info-circle"}],"\n        "],"\n    \n    ",["DIV",{"class":"alert-body"},["P",{"class":"MsoNormal"},"From 1 April, householders will need to provide their own refuse bags, ensuring that the bags are no larger than 60 litres - ",["A",{"class":"alert-link","href":"/news/residents-update-on-the-changes-to-the-supply-of-blue-refuse-sacks/","title":"Residents’ update on the changes to the supply of blue refuse sacks"},"Changes to the supply of blue refuse sacks"]]],"\n"],"\n\n\n",["DIV",{"class":"richtext-block"},["P",{},"We provide a fortnightly waste collection for materials that cannot be recycled at the kerbside."],"\n",["P",{},"There is two bag limit per fortnight."],"\n",["P",{},"Please remember to ",["STRONG",{},"place at the kerbside before 7am"]," on your collection day. Be careful when placing your bags out for collection to avoid blocking the pavement."],"\n",["P",{},["STRONG",{},"Do not place bags out before 7pm "],"the night before your collection as this can cause littering problems.  "],"\n",["P",{},"Residents who put their bags out outside of these times could receive a £100 fixed penalty notice or even prosecution under the Environmental Protection Act 1990."]],"\n\n\n\n",["DIV",{"class":"button-container"},"\n    ",["A",{"href":"https://bridgendportal.azurewebsites.net/","title":"Find out your waste and recycling collection day","class":"btn btn-secondary"},"\n        Find out your waste and recycling collection day\n    "],"\n"],"\n\n\n",["DIV",{"class":"tick-cross-list"},"\n        ",["P",{},["STRONG",{},"Please do not place the following in your waste bags:"]],"\n    ",["UL",{"class":"fa-ul"},"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," garden waste\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," DIY items such as paint, stones, rubble or builders’ waste\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," clinical waste such as medical waste or needles\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," dead animals\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," cooking or engine oil\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," electrical items\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," trade waste\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," hazardous waste such as solvents and chemicals\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," batteries\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," fluorescent tubes or light bulbs containing mercury\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-li"},["I",{"class":"fa-solid fa-xmark"}]]," poison or baits\n            "],"\n            ",["LI",{},"\n                ",["SPAN",{"class":"fa-l