--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["UL",{},"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Monday%20%28Week%201%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"911e092d-f46f-42d5-820e-d09fb01f0c79","data-entity-substitution":"media"},"Monday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Tuesday%20%28Week%201%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"1348ebe9-f8ca-4a9d-8633-db39ef883fdf","data-entity-substitution":"media"},"Tuesday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Wednesday%20%28Week%201%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"57d4175c-a06f-4078-a8d1-299aee286222","data-entity-substitution":"media"},"Wednesday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Thursday%20%28Week%201%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"daa359d3-00e1-439e-9d1c-7fd4ccc6a63a","data-entity-substitution":"media"},"Thursday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Friday%20%28Week%201%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"99290813-95ac-4604-8508-cad14d69ba33","data-entity-substitution":"media"},"Friday"]],"\n"],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-4217","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"Garden waste bin collections (week 2)"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-0-2"},"\n            Garden waste bin collections (week 2)\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-0-2"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["UL",{},"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Monday%20%28Week%202%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"3f3b8bbe-92d8-4a11-83ef-0923ba33b6f1","data-entity-substitution":"media"},"Monday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Tuesday%20%28Week%202%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"d370d8c6-3be7-4a2d-b8b7-998cd501b0d9","data-entity-substitution":"media"},"Tuesday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Wednesday%20%28Week%202%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"a72960de-47eb-40f1-8baf-372fe1fd9917","data-entity-substitution":"media"},"Wednesday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Thursday%20%28Week%202%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"a87da1ba-ed38-4c82-bec5-cde0395b7ea8","data-entity-substitution":"media"},"Thursday"]],"\n",["LI",{},["A",{"href":"/sites/default/files/2025-01/Brown%20Garden%20Bin%20Calendar%20Friday%20%28Week%202%29%202025-2026.pdf","data-entity-type":"media","data-entity-uuid":"276d5f9c-f537-4b12-ae4c-3751fbf4971f","data-entity-substitution":"media"},"Friday"]],"\n"],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n          "],"\n  \n      "],"\n"],"\n      "],"\n              ",["DIV",{"class":"field__item"},"\n            ",["DIV",{"class":"field field--name-label field--type-string field--label-hidden field__item"},"text | find your bin collection day (email reminders)"],"\n      \n            ",["DIV",{"class":"field field--name-paragraphs field--type-entity-reference-revisions field--label-hidden field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_text-3748","class":"paragraph paragraph--type--localgov-text paragraph--view-mode--default"},"\n          \n            ",["DIV",{"class":"field field--name-localgov-text field--type-text-long field--label-hidden field__item"},["H2",{"id":"email-reminder-service"},"Email reminder service"],"\n",["P",{},"You can sign up to receive email reminders of upcoming bin days. On the evenings prior to your bin collection day, we can send you an email at 5pm to remind you of your upcoming collection and to tell you which colour of bin we will be collecting. You can sign up for this via the ",["A",{"href":"https://www.n-kesteven.org.uk/bins/"},"find your bin collection day tool"],". "],"\n",["P",{},"Simply search for your postcode and select your address from the list. Once you have selected your address, information on your recent and upcoming collections can be seen and you will be able to enter your email address to sign up for the email reminder service."]],"\n      \n      "],"\n"],"\n      "],"\n              ",["DIV",{"class":"field__item"},"\n            ",["DIV",{"class":"field field--name-label field--type-string field--label-hidden field__item"},"accordion | bin day email reminder FAQs"],"\n      \n            ",["DIV",{"class":"field field--name-paragraphs field--type-entity-reference-revisions field--label-hidden field__item"},"\n\n\n\n  ",["DIV",{"data-id":"paragraphs-localgov_accordion-3757","class":"paragraph paragraph--type--localgov-accordion paragraph--view-mode--default accordion accordion--initialised"},"\n          \n            \n      ",["DIV",{"class":"field field--name-localgov-paragraphs field--type-entity-reference-revisions field--label-hidden field__items"},"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3749","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"How does it work?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-0"},"\n            How does it work?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-0"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"Once subscribed, you will begin to receive emails at 5pm on evenings before you have a bin due for collection. This email will also include the colour of the bin that is due for collection."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3750","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"Can I unsubscribe?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-1"},"\n            Can I unsubscribe?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-1"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"You can unsubscribe at any time by clicking on the link at the bottom of the bin reminder emails. Alternatively, you can access your ",["A",{"href":"https://public.govdelivery.com/accounts/UKNORTHKESTEVEN/subscriber/new"},"email subscription preferences"]," to amend what you receive at any time."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3751","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"How do I change details if I move?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-2"},"\n            How do I change details if I move?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-2"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"We can only store one set of bin collection data against an individual email address. If you have moved from one address in North Kesteven to another, you can search for your new address on the ",["A",{"href":"https://www.n-kesteven.org.uk/bins/"},"find my bin day online tool"]," and enter your email address to subscribe to bin collection day updates for your new address. This will automatically remove your previous associated address and bin day information."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3752","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"Does this include Garden Waste bins?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-3"},"\n            Does this include Garden Waste bins?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-3"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"Yes, if you are a member of the Garden Waste service at the time of signing up for email reminders, you will also receive emails the evening before your brown garden waste bin is due for collection."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3753","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"My Garden Waste subscription has changed since I signed up, can I adjust this?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-4"},"\n            My Garden Waste subscription has changed since I signed up, can I adjust this?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-4"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"Yes, if you have since joined/ left the Garden Waste service since signing up for email reminders, your reminders can be adjusted to reflect this."],"\n",["P",{},"You can search for your address on the ",["A",{"href":"https://www.n-kesteven.org.uk/bins/"},"find my bin day online tool"]," and enter your email address to subscribe to bin collection day updates as you may have done previously. This will automatically update your previous bin day information and your garden waste status will be included in this."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3754","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"Can I change the time at which I receive my email?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-5"},"\n            Can I change the time at which I receive my email?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-5"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"No, unfortunately not."],"\n"],"\n      \n        \n      "],"\n      "],"\n"],"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"data-id":"paragraphs-localgov_accordion_pane-3755","class":"paragraph paragraph--type--localgov-accordion-pane paragraph--view-mode--default accordion-pane accordion-pane-parent"},"\n          ",["DIV",{"class":"accordion-pane__title"},"\n        ",["H3",{},"\n          ",["SPAN",{"class":"accordion-pane__heading","hidden":""},"Why can't I find my address when signing up for this service?"],"\n          ",["BUTTON",{"aria-expanded":"false","aria-controls":"accordion-content-1-6"},"\n            Why can't I find my address when signing up for this service?\n          "],"\n        "],"\n        ",["svg",{"class":"svg-inline--fa fa-angle-down","aria-hidden":"true","focusable":"false","data-prefix":"fas","data-icon":"angle-down","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 448 512","data-fa-i2svg":""},["path",{"fill":"currentColor","d":"M201.4 374.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 306.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"}]],"\n      "],"\n      ",["DIV",{"class":"accordion-pane__content","id":"accordion-content-1-6"},"\n        \n            ",["DIV",{"class":"field field--name-localgov-body-text field--type-text-long field--label-hidden field__item"},["P",{},"Please make sure your address is within North Kesteven."],"\n",["P",{},"If you are confident you live within our district but still cannot locate your address in order to sign up for bin day email reminders, please email ",["A",{"href":"mailto:customer_services@n-kesteven.gov.uk","class":"mailto","data-extlink":""},"",["SPAN",{"class":"extlink-nobreak"},"customer_services@n-kesteven.gov.uk",["SPAN",{"class":"fa-mailto extlink","aria-label":"link sends email","role":"img","aria-hidden":"false"},["svg