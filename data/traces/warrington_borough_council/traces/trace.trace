{"type":"before","callId":"call@88","startTime":51459.992,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const getBinInfo = (binName) => {\n        const h3Elements = Array.from(document.querySelectorAll(\"h3\"));\n        const binHeading = h3Elements.find(h3 => h3.textContent.includes(binName));\n        if (binHeading) {\n            const nextPickupDay = binHeading.nextElementSibling ? binHeading.nextElementSibling.textContent.trim() : null;\n            const frequency = binHeading.nextElementSibling && binHeading.nextElementSibling.nextElementSibling ? binHeading.nextElementSibling.nextElementSibling.textContent.trim() : null;\n            return { next_pickup_day: nextPickupDay, frequency: frequency };\n        }\n        return { next_pickup_day: null, frequency: null };\n    };\n\n    const generalWasteInfo = getBinInfo(\"General waste bin\");\n    const recyclingInfo = getBinInfo(\"Recycling bin\");\n    const gardenWasteInfo = getBinInfo(\"Garden waste bin\");\n    const foodWasteInfo = getBinInfo(\"Food waste bin\");\n\n    return {\n        generalWaste: {\n            next_pickup_day: generalWasteInfo.next_pickup_day,\n            frequency: generalWasteInfo.frequency,\n            bin_colour: 'black'\n        },\n        recycling: {\n            next_pickup_day: recyclingInfo.next_pickup_day,\n            frequency: recyclingInfo.frequency,\n            bin_colour: 'blue'\n        },\n        gardenWaste: {\n            next_pickup_day: gardenWasteInfo.next_pickup_day,\n            frequency: gardenWasteInfo.frequency,\n            bin_colour: 'green'\n        },\n        foodWaste: {\n            next_pickup_day: foodWasteInfo.next_pickup_day,\n            frequency: foodWasteInfo.frequency,\n            bin_colour: 'brown'\n        }\n    };\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@1bbe9ba4da8654f141667994948e6ebc","beforeSnapshot":"before@call@88"}
