{"type":"before","callId":"call@86","startTime":47206.69,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const generalWaste = document.querySelector('h3:contains(\"General waste bin\")');\n    const generalWasteNextPickup = generalWaste ? generalWaste.nextElementSibling.innerText.trim() : null;\n    const generalWasteFrequency = generalWaste ? generalWaste.nextElementSibling.nextElementSibling.innerText.trim() : null;\n\n    const recycling = document.querySelector('h3:contains(\"Recycling bin\")');\n    const recyclingNextPickup = recycling ? recycling.nextElementSibling.innerText.trim() : null;\n    const recyclingFrequency = recycling ? recycling.nextElementSibling.nextElementSibling.innerText.trim() : null;\n\n    const gardenWaste = document.querySelector('h3:contains(\"Garden waste bin\")');\n    const gardenWasteNextPickup = gardenWaste ? gardenWaste.nextElementSibling.innerText.trim() : null;\n    const gardenWasteFrequency = gardenWaste ? gardenWaste.nextElementSibling.nextElementSibling.innerText.trim() : null;\n\n    const foodWaste = document.querySelector('h3:contains(\"Food waste bin\")');\n    const foodWasteNextPickup = foodWaste ? foodWaste.nextElementSibling.innerText.trim() : null;\n    const foodWasteFrequency = foodWaste ? foodWaste.nextElementSibling.nextElementSibling.innerText.trim() : null;\n\n    return {\n        generalWaste: {\n            next_pickup_day: generalWasteNextPickup,\n            frequency: generalWasteFrequency,\n            bin_colour: 'black'\n        },\n        recycling: {\n            next_pickup_day: recyclingNextPickup,\n            frequency: recyclingFrequency,\n            bin_colour: 'blue'\n        },\n        gardenWaste: {\n            next_pickup_day: gardenWasteNextPickup,\n            frequency: gardenWasteFrequency,\n            bin_colour: 'green'\n        },\n        foodWaste: {\n            next_pickup_day: foodWasteNextPickup,\n            frequency: foodWasteFrequency,\n            bin_colour: 'brown'\n        }\n    };\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@1bbe9ba4da8654f141667994948e6ebc","beforeSnapshot":"before@call@86"}
