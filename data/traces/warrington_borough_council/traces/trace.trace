{"type":"after","callId":"call@86","endTime":47221.662,"error":{"message":"SyntaxError: Failed to execute 'querySelector' on 'Document': 'h3:contains(\"General waste bin\")' is not a valid selector.\n    at eval (eval at evaluate (:291:30), <anonymous>:2:35)\n    at UtilityScript.evaluate (<anonymous>:293:16)\n    at UtilityScript.<anonymous> (<anonymous>:1:44)","stack":"Error: SyntaxError: Failed to execute 'querySelector' on 'Document': 'h3:contains(\"General waste bin\")' is not a valid selector.\n    at eval (eval at evaluate (:291:30), <anonymous>:2:35)\n    at UtilityScript.evaluate (<anonymous>:293:16)\n    at UtilityScript.<anonymous> (<anonymous>:1:44)\n    at CRExecutionContext.evaluateWithArguments (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/chromium/crExecutionContext.js:80:13)\n    at async LongStandingScope._race (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/utils/isomorphic/manualPromise.js:94:14)\n    at async Object.evaluateExpression (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/javascript.js:217:12)\n    at async Frame.evaluateExpression (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/frames.js:590:19)\n    at async FrameDispatcher.evaluateExpression (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/dispatchers/frameDispatcher.js:76:68)\n    at async ProgressController.run (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/progress.js:139:41)\n    at async FrameDispatcher._runCommand (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/dispatchers/dispatcher.js:91:14)\n    at async DispatcherConnection.dispatch (/Users/christophersteinberg/.npm/_npx/9833c18b2d85bc59/node_modules/playwright-core/lib/server/dispatchers/dispatche