ent html non-input ","data-content":"<div class=\"alert alert-warning\" style=\"color:black\">\n<strong>Garden waste collection</strong><br /><br />Our records indicate that you have not paid for the current Garden Waste Collection Service so ONLY your recycling will be collected on days where a garden waste collection is due<br /><br />To pay for the Garden Waste Collection Service, please visit <strong><a href=wrexham.gov.uk/gardenwaste=\"_self\">wrexham.gov.uk/gardenwaste.</a></strong><br /><br />If you have already paid for this service please email contact-us@wrexham.gov.uk quoting your receipt number and address.\n</div>","data-display-condition":"{ExistingCheck/NoOfGreenBins} icontains '0' and ({uprn} isnt '' or {Address/SelectedUPRN} isnt '')"},["DIV",{"class":"alert alert-warning","style":"color:black"},"\n",["STRONG",{},"Garden waste collection"],["BR"],["BR"],"Our records indicate that you have not paid for the current Garden Waste Collection Service so ONLY your recycling will be collected on days where a garden waste collection is due",["BR"],["BR"],"To pay for the Garden Waste Collection Service, please visit ",["STRONG",{},["A",{"href":"wrexham.gov.uk/gardenwaste=\"_self\""},"wrexham.gov.uk/gardenwaste."]],["BR"],["BR"],"If you have already paid for this service please email contact-us@wrexham.gov.uk quoting your receipt number and address.\n"]],[[5,566]]],[[5,568]]],[[5,575]],[[5,586]],[[5,597]],[[5,608]],[[5,619]],[[5,630]],[[5,641]],[[5,652]],[[5,663]],[[5,674]],["DIV",{"class":"field fs-hidden","data-field-name":"ExistingCheck","data-field-type":"subform","data-inline-subform":"true","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},[[5,682]],[[5,683]],["FIELDSET",{"data-name":"ExistingCheck","data-type":"subform","class":"col-xs-12 col-sm-12   required fs-hidden inlineSubform  subformInput fieldInput subform ","data-display-style":"summary","required":"true","data-hidden":"true","data-form-id":"AF-Form-991009f5-1386-4435-82f6-a093a06a0